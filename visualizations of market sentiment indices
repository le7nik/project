    # Выводим результаты в консоль
    for name, val, cls in sources:
        if val is not None:
            print(f"{name}: {val} ({cls})")
        else:
            print(f"{name}: Данные недоступны")
    
    # Рисуем шкалу
    plot_gauge(sources)



